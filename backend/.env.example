# Flask environment configuration
FLASK_APP=app.py
FLASK_DEBUG=True
FLASK_PORT=5000

# Secret key for signing JWTs (Change this to a strong, unique key in production!)
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database connection URI
# SQLite default: sqlite:///db.sqlite3 (stored in instance folder)
# PostgreSQL example: postgresql://username:password@localhost:5432/stackit
DATABASE_URL=sqlite:///db.sqlite3

# Permitted CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
